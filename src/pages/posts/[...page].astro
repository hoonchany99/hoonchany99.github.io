---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { topicHubs } from '../../data/topicHubs';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('posts')).sort(
    (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)
  );
  return paginate(posts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

function getExcerpt(body: string, maxLen = 100): string {
  const text = body.replace(/<[^>]+>/g, '').replace(/&[a-z]+;/gi, ' ').replace(/\s+/g, ' ').trim();
  if (text.length <= maxLen) return text;
  return text.slice(0, maxLen).replace(/\s\S*$/, '') + '…';
}

function getReadingTime(body: string): number {
  const text = body.replace(/<[^>]+>/g, '').replace(/&[a-z]+;/gi, ' ').replace(/\s+/g, ' ').trim();
  return Math.max(1, Math.round(text.length / 500));
}

const totalPages = page.lastPage;
const currentPage = page.currentPage;
---

<BaseLayout title={currentPage === 1 ? '블로그' : `블로그 - ${currentPage}페이지`} description={currentPage === 1 ? '충치, 신경치료, 임플란트, 사랑니, 라미네이트, 크라운, 스케일링까지. 서울대 치의학대학원 출신 치과의사가 환자들이 가장 자주 묻는 치과 질문에 정확하고 쉽게 답합니다. 100편 이상의 치과 정보 글을 확인하세요.' : `서울대 윤원장의 치과 정보 블로그 ${currentPage}페이지입니다. 충치, 임플란트, 사랑니, 신경치료, 라미네이트, 크라운, 잇몸 관리까지 서울대 치의학대학원 출신 치과의사가 주제별로 정리한 ${totalPages * 12}편 이상의 치과 건강 정보를 확인하세요.`}>
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 anim-fade-up">
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">블로그</h1>
        <p class="text-lg text-gray-600">정확하고, 쉽게 이해되고, 믿을 수 있는 치과 정보</p>
      </div>

      <!-- 검색 -->
      <div class="mb-10 max-w-lg mx-auto anim-fade-up">
        <div class="flex gap-2">
          <div class="relative flex-1">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input
              id="blog-search"
              type="text"
              placeholder="궁금한 치과 질문이나 치료명을 입력해보세요"
              class="w-full pl-12 pr-4 py-2.5 md:py-3 rounded-xl border border-gray-200 focus:border-brand focus:ring-2 focus:ring-brand/20 outline-none text-[16px] leading-tight md:text-sm transition-all bg-white"
            />
          </div>
          <button
            id="ai-search-btn"
            class="w-11 h-11 md:w-auto md:h-auto md:px-4 md:py-3 rounded-xl bg-brand text-white text-sm font-bold hover:bg-brand-dark disabled:opacity-40 disabled:cursor-not-allowed transition-all shrink-0 flex items-center justify-center"
            disabled
          >
            <svg class="w-5 h-5 md:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <span class="hidden md:inline">질문해보기</span>
          </button>
        </div>
        <p id="search-hint" class="text-center text-[11px] text-gray-400 mt-2">질문을 입력하고 버튼을 누르면, AI가 관련 글을 찾고 짧게 정리해드립니다</p>
        <div id="search-results" class="mt-4 hidden"></div>
      </div>

      <!-- 주제 필터 칩 -->
      <div class="mb-8 anim-fade-up overflow-x-auto scrollbar-hide -mx-4 px-4 md:mx-0 md:px-0">
        <div class="flex items-center gap-1.5 md:gap-2 md:flex-wrap md:justify-center w-max md:w-auto">
          {topicHubs.map((hub) => (
            <a
              href={`/topics/${hub.slug}/`}
              class="inline-flex items-center gap-1 md:gap-1.5 px-3 md:px-4 py-2 rounded-full text-xs md:text-sm font-medium bg-white border border-gray-200 text-gray-600 hover:border-brand/40 hover:text-brand hover:bg-brand/5 transition-all min-h-[40px] whitespace-nowrap shrink-0"
            >
              <span>{hub.icon}</span>
              <span>{hub.name}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {page.data.map((post, i) => (
          <a href={`/posts/${post.slug}/`} class={`anim-fade-up anim-delay-${Math.min(i + 1, 3)} bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-0.5 group border border-gray-100 flex flex-row`}>
            <div class="hidden sm:block sm:w-32 md:w-40 flex-shrink-0 overflow-hidden bg-gradient-to-br from-teal-50 to-cyan-50">
              {post.data.image?.path ? (
                <img
                  src={post.data.image.path}
                  alt={post.data.image.alt || post.data.title}
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
              ) : (
                <div class="w-full h-full min-h-[160px] flex items-center justify-center">
                  <div class="text-5xl">📝</div>
                </div>
              )}
            </div>
            <div class="p-5 sm:p-6 flex flex-col justify-center flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-3 flex-wrap">
                {post.data.categories?.[0] && (
                  <span class="bg-brand/10 text-brand px-3 py-0.5 rounded-full text-xs font-semibold">{post.data.categories[0]}</span>
                )}
                {post.data.date && (
                  <span class="text-xs text-gray-400">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                )}
                <span class="text-xs text-gray-400">{getReadingTime(post.body)}분 읽기</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand transition-colors leading-snug">{post.data.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{getExcerpt(post.body)}</p>
              <div class="flex items-center text-brand font-semibold mt-3 text-sm group-hover:gap-2 transition-all">
                <span>더 읽기 →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      {page.data.length === 0 && (
        <p class="text-center text-gray-500 py-20">아직 작성된 글이 없습니다.</p>
      )}

      <!-- 페이지네이션 -->
      {totalPages > 1 && (
        <nav id="pagination-nav" class="mt-16 flex items-center justify-center gap-2" aria-label="페이지 이동">
          {page.url.prev ? (
            <a href={page.url.prev} class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">
              ← 이전
            </a>
          ) : (
            <span class="px-3 py-2 rounded-lg text-sm font-medium text-gray-300 cursor-not-allowed">
              ← 이전
            </span>
          )}

          {Array.from({ length: totalPages }, (_, i) => i + 1).map((num) => {
            const url = num === 1 ? '/posts/' : `/posts/${num}/`;
            const isActive = num === currentPage;
            return (
              <a
                href={url}
                class={`w-10 h-10 flex items-center justify-center rounded-lg text-sm font-semibold transition-colors ${
                  isActive
                    ? 'bg-brand text-white'
                    : 'text-gray-600 hover:bg-gray-100'
                }`}
                aria-current={isActive ? 'page' : undefined}
              >
                {num}
              </a>
            );
          })}

          {page.url.next ? (
            <a href={page.url.next} class="px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors">
              다음 →
            </a>
          ) : (
            <span class="px-3 py-2 rounded-lg text-sm font-medium text-gray-300 cursor-not-allowed">
              다음 →
            </span>
          )}
        </nav>
      )}

      <div id="post-count" class="text-center mt-6 text-sm text-gray-400">
        총 {page.total}개의 글
      </div>
    </div>
  </section>

  <script>
    const WORKER_URL = 'https://doctoryoon-summarize.hoonchany99.workers.dev';
    const DISCLAIMER = '일반적인 정보를 안내하며, 실제 진단과 치료 계획은 검사에 따라 달라질 수 있습니다.';

    const input = document.getElementById('blog-search') as HTMLInputElement;
    const aiBtn = document.getElementById('ai-search-btn') as HTMLButtonElement;
    const resultsEl = document.getElementById('search-results')!;
    const searchHint = document.getElementById('search-hint');
    const cardGrid = document.querySelector('.grid.md\\:grid-cols-2') as HTMLElement;
    const topicChips = document.querySelector('.mb-8.flex.flex-wrap') as HTMLElement;
    const paginationNav = document.getElementById('pagination-nav');
    const postCount = document.getElementById('post-count');
    let posts: any[] = [];
    let loaded = false;
    let aiMode = false;

    function showGrid() {
      if (cardGrid) cardGrid.style.display = '';
      if (topicChips) topicChips.style.display = '';
      if (paginationNav) paginationNav.style.display = '';
      if (postCount) postCount.style.display = '';
      if (searchHint) searchHint.style.display = '';
      resultsEl.classList.add('hidden');
      resultsEl.innerHTML = '';
      aiMode = false;
    }

    function hideGrid() {
      if (cardGrid) cardGrid.style.display = 'none';
      if (topicChips) topicChips.style.display = 'none';
      if (paginationNav) paginationNav.style.display = 'none';
      if (postCount) postCount.style.display = 'none';
      if (searchHint) searchHint.style.display = 'none';
      resultsEl.classList.remove('hidden');
    }

    async function loadIndex() {
      if (loaded) return;
      const res = await fetch('/search.json');
      posts = await res.json();
      loaded = true;
    }

    function highlight(text: string, q: string) {
      if (!q) return text;
      const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(re, '<mark class="bg-yellow-100 text-inherit rounded px-0.5">$1</mark>');
    }

    function formatDate(iso: string) {
      return new Date(iso).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    function showKeywordResults(q: string) {
      const matches = posts.filter((p: any) =>
        p.title.toLowerCase().includes(q) ||
        p.description.toLowerCase().includes(q) ||
        p.excerpt.toLowerCase().includes(q) ||
        p.tags.some((t: string) => t.toLowerCase().includes(q)) ||
        p.categories.some((c: string) => c.toLowerCase().includes(q))
      ).slice(0, 12);

      hideGrid();

      if (matches.length === 0) {
        resultsEl.innerHTML = `<p class="text-center text-gray-400 py-12">"${input.value}" 검색 결과가 없습니다</p>`;
        return;
      }

      resultsEl.innerHTML = `
        <p class="text-sm text-gray-400 mb-4">${matches.length}개의 검색 결과</p>
        <div class="flex flex-col gap-3">
          ${matches.map((p: any) => `
            <a href="/posts/${p.slug}/" class="block bg-white rounded-xl px-5 py-4 border border-gray-100 hover:border-[#3FB8D3]/40 hover:shadow-md transition-all group">
              <h3 class="font-bold text-gray-900 group-hover:text-[#3FB8D3] transition-colors leading-snug mb-1">${highlight(p.title, q)}</h3>
              <p class="text-gray-500 text-sm line-clamp-1 mb-2">${highlight(p.excerpt.slice(0, 120), q)}</p>
              <div class="flex items-center gap-2 text-xs text-gray-400">
                ${p.categories[0] ? `<span class="text-[#3FB8D3] font-medium">${p.categories[0]}</span><span>·</span>` : ''}
                ${p.date ? `<span>${formatDate(p.date)}</span><span>·</span>` : ''}
                <span>${p.readingTime}분 읽기</span>
              </div>
            </a>
          `).join('')}
        </div>
        <button id="ai-cta-banner" class="mt-5 w-full flex items-center justify-center gap-2 py-3.5 px-4 rounded-xl border border-dashed border-[#3FB8D3]/30 bg-[#3FB8D3]/[0.03] hover:bg-[#3FB8D3]/[0.07] hover:border-[#3FB8D3]/50 transition-all group cursor-pointer">
          <svg class="w-4 h-4 text-[#3FB8D3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          <span class="text-xs font-semibold text-[#3FB8D3] group-hover:text-[#3FB8D3]">이 질문, AI로 더 정확하게 찾아볼까요?</span>
          <span class="text-[10px] text-gray-400">관련 글 + 짧은 요약</span>
        </button>
      `;

      document.getElementById('ai-cta-banner')?.addEventListener('click', () => {
        showAiResults(input.value.trim());
      });
    }

    async function showAiResults(query: string) {
      aiMode = true;
      hideGrid();

      resultsEl.innerHTML = `
        <div class="text-center py-16">
          <div class="inline-block w-8 h-8 border-[2.5px] border-[#3FB8D3]/20 border-t-[#3FB8D3] rounded-full animate-spin mb-4"></div>
          <p class="text-sm text-gray-600 font-medium">관련 글을 찾고 있습니다</p>
          <p class="text-xs text-gray-400 mt-1">잠시만 기다려주세요</p>
        </div>
      `;

      try {
        const res = await fetch(WORKER_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query }),
        });

        if (!res.ok) throw new Error('Worker error');
        const data = await res.json() as { summary: string | null; results: any[] };

        if (!data.results || data.results.length === 0) {
          resultsEl.innerHTML = `
            <div class="text-center py-16">
              <p class="text-sm font-semibold text-gray-700 mb-1.5">딱 맞는 글을 찾지 못했습니다</p>
              <p class="text-xs text-gray-500 mb-6">다른 표현으로 다시 질문해보시거나, 주제별 가이드를 살펴보세요.</p>
              <a href="/topics/" class="text-xs px-4 py-2 rounded-lg bg-[#3FB8D3] text-white font-bold hover:opacity-90 transition-all">주제별 가이드 보기</a>
            </div>
          `;
          return;
        }

        const summaryHtml = data.summary
          ? `<div class="bg-[#3FB8D3]/[0.03] rounded-2xl p-5 border border-[#3FB8D3]/10 mb-5">
              <div class="flex items-center gap-1.5 mb-2.5">
                <span class="w-1.5 h-1.5 rounded-full bg-[#3FB8D3]"></span>
                <p class="text-xs font-bold text-[#3FB8D3]">짧게 정리하면</p>
              </div>
              <p id="ai-summary-text" class="text-sm text-gray-700 leading-[1.8]"></p>
            </div>`
          : '';

        const cardsHtml = data.results.map((r: any, i: number) => `
          <a href="/posts/${r.slug}/" class="flex items-start gap-4 bg-white rounded-xl border border-gray-100 p-4 hover:shadow-md hover:border-[#3FB8D3]/20 hover:-translate-y-0.5 transition-all group">
            <span class="shrink-0 w-6 h-6 rounded-full bg-gray-100 text-[11px] font-bold text-gray-400 flex items-center justify-center mt-0.5">${i + 1}</span>
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-bold text-gray-900 group-hover:text-[#3FB8D3] transition-colors mb-1">${r.title}</h3>
              <p class="text-xs text-gray-500 leading-relaxed line-clamp-2">${r.excerpt}</p>
              ${r.tags?.length ? `<div class="flex flex-wrap gap-1.5 mt-2">${r.tags.slice(0, 3).map((t: string) => `<span class="text-[10px] px-2 py-0.5 rounded-full bg-gray-50 text-gray-400 border border-gray-100">${t}</span>`).join('')}</div>` : ''}
            </div>
          </a>
        `).join('');

        const hiddenStyle = data.summary ? 'opacity:0;transform:translateY(8px);' : '';

        resultsEl.innerHTML = `
          <div class="max-w-3xl mx-auto space-y-5">
            ${summaryHtml}
            <div id="ai-cards-section" style="transition:opacity 0.5s,transform 0.5s;${hiddenStyle}">
              <p class="text-sm font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span class="w-1 h-4 bg-[#3FB8D3] rounded-full inline-block"></span>
                이 질문과 관련된 글
              </p>
              <div class="space-y-2.5">${cardsHtml}</div>
            </div>
            <div id="ai-footer-section" class="pt-4 border-t border-gray-100" style="transition:opacity 0.5s,transform 0.5s;${hiddenStyle}">
              <p class="text-[11px] text-gray-400 text-center leading-relaxed mb-4">${DISCLAIMER}</p>
              <div class="flex flex-wrap gap-2.5 justify-center">
                <button id="ai-reset" class="text-xs px-4 py-2 rounded-lg border border-gray-200 text-gray-500 hover:border-[#3FB8D3]/40 hover:text-[#3FB8D3] transition-all">다른 질문하기</button>
                <a href="/topics/" class="text-xs px-4 py-2 rounded-lg border border-gray-200 text-gray-500 hover:border-[#3FB8D3]/40 hover:text-[#3FB8D3] transition-all">주제별 가이드 보기</a>
              </div>
            </div>
          </div>
        `;

        document.getElementById('ai-reset')?.addEventListener('click', () => {
          input.value = '';
          showGrid();
          input.focus();
        });

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const cards = document.getElementById('ai-cards-section');
            const footer = document.getElementById('ai-footer-section');
            if (cards) { cards.style.opacity = '1'; cards.style.transform = 'translateY(0)'; }
            setTimeout(() => {
              if (footer) { footer.style.opacity = '1'; footer.style.transform = 'translateY(0)'; }
            }, 200);

            if (!document.getElementById('blink-cursor-style')) {
              const style = document.createElement('style');
              style.id = 'blink-cursor-style';
              style.textContent = '@keyframes blink-cursor{0%,100%{opacity:1}50%{opacity:0}}';
              document.head.appendChild(style);
            }

            const el = document.getElementById('ai-summary-text');
            if (el) {
              const text = data.summary!;
              let idx = 0;
              const cursor = document.createElement('span');
              cursor.style.cssText = 'display:inline-block;width:2px;height:1em;background:#3FB8D3;margin-left:2px;vertical-align:middle;animation:blink-cursor 0.8s step-end infinite;';
              el.textContent = '';
              el.appendChild(cursor);
              const timer = setInterval(() => {
                idx++;
                el.textContent = text.slice(0, idx);
                el.appendChild(cursor);
                if (idx >= text.length) {
                  clearInterval(timer);
                  cursor.remove();
                }
              }, 22);
            }
          });
        });
      } catch {
        aiMode = false;
        await loadIndex();
        showKeywordResults(query.toLowerCase());
      }
    }

    input?.addEventListener('focus', loadIndex);

    input?.addEventListener('input', async () => {
      aiBtn.disabled = !input.value.trim();
      if (aiMode) return;
      await loadIndex();
      const q = input.value.trim().toLowerCase();
      if (!q) { showGrid(); return; }
      showKeywordResults(q);
    });

    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const q = input.value.trim();
        if (q) showAiResults(q);
      }
    });

    aiBtn?.addEventListener('click', () => {
      const q = input.value.trim();
      if (q) showAiResults(q);
    });

    // ?q= 파라미터로 자동 AI 검색
    const urlQ = new URLSearchParams(window.location.search).get('q');
    if (urlQ && input) {
      input.value = urlQ;
      showAiResults(urlQ);
    }
  </script>
</BaseLayout>
