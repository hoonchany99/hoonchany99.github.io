---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { topicHubs, findTopicHub, topicIcons } from '../../data/topicHubs';

const posts = await getCollection('posts');

const hubCounts = topicHubs.map((hub) => {
  const count = posts.filter((post) => {
    const tags = post.data.tags ?? [];
    const matched = findTopicHub(tags);
    return matched?.slug === hub.slug;
  }).length;
  return { ...hub, count };
});
---

<BaseLayout
  title="주제별 치과 정보"
  description="충치, 임플란트, 크라운, 사랑니, 라미네이트, 잇몸 등 주제별로 정리된 치과 건강 정보를 한눈에 확인하세요."
  breadcrumbs={[
    { name: '홈', url: '/' },
    { name: '주제별', url: '/topics/' },
  ]}
>
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 anim-fade-up">
        <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">주제별 치과 정보</h1>
        <p class="text-lg text-gray-600">내 증상, 내 치료에 맞는 글을 찾아보세요</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {hubCounts.map((hub, i) => (
          <a
            href={`/topics/${hub.slug}/`}
            class={`anim-fade-up anim-delay-${Math.min(i + 1, 3)} group relative bg-white rounded-2xl border border-gray-100 p-6 md:p-8 hover:shadow-xl hover:border-brand/30 hover:-translate-y-1 transition-all`}
          >
            <div class="w-[72px] h-12 md:w-24 md:h-16 text-brand mb-4" set:html={topicIcons[hub.slug] ?? hub.icon} />
            <h2 class="text-lg md:text-xl font-bold text-gray-900 group-hover:text-brand transition-colors mb-2">{hub.name}</h2>
            <p class="text-sm text-gray-500 leading-relaxed mb-4 line-clamp-2">{hub.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-brand bg-brand/10 px-3 py-1 rounded-full">{hub.count}편</span>
              <span class="text-sm text-gray-400 group-hover:text-brand group-hover:translate-x-1 transition-all">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
