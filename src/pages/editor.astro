---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParagraphSpacingEditor from '../components/ParagraphSpacingEditor';
---

<BaseLayout
  title="Paragraph Spacing Editor"
  description="A rich text editor that preserves visible spacing between paragraphs, headings, and horizontal rules when copying text from ChatGPT to Naver."
  noindex={true}
>
  <section class="py-16 bg-gray-50 min-h-[calc(100vh-4rem)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <p class="text-sm font-semibold text-brand uppercase tracking-[0.18em]">Utility tool</p>
        <h1 class="mt-3 text-3xl md:text-4xl font-extrabold text-gray-900">ChatGPT → Naver paragraph spacing editor</h1>
        <p class="mt-4 text-lg text-gray-600 leading-relaxed max-w-3xl">
          Paste copied output from ChatGPT into this editor first. It keeps paragraphs, headings, lists, and horizontal rules as visible blocks, so you can copy the cleaned result into Naver with better spacing.
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-4 sm:p-6">
        <ParagraphSpacingEditor client:load />
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-3 text-sm text-gray-600">
        <div class="rounded-xl border border-gray-200 bg-white p-4">
          <div class="font-semibold text-gray-900 mb-2">1. Copy from ChatGPT</div>
          Paste markdown-rendered text or rich text into the editor.
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-4">
          <div class="font-semibold text-gray-900 mb-2">2. Let it normalize</div>
          Paragraphs, headings, and HRs keep their block spacing automatically.
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-4">
          <div class="font-semibold text-gray-900 mb-2">3. Copy to Naver</div>
          Select all or use the copy button, then paste into Naver.
        </div>
      </div>
    </div>
  </section>

  <style is:global>
    .editor-btn {
      border: 1px solid #d1d5db;
      background: white;
      color: #374151;
      border-radius: 10px;
      padding: 0.55rem 0.8rem;
      font-size: 0.875rem;
      font-weight: 600;
      transition: all 0.15s ease;
    }

    .editor-btn:hover {
      border-color: #3fb8d3;
      color: #0f766e;
      background: #f8fdff;
    }

    .editor-btn-primary {
      border-color: #3fb8d3;
      background: #3fb8d3;
      color: white;
    }

    .editor-btn-primary:hover {
      background: #2ea3bd;
      border-color: #2ea3bd;
      color: white;
    }

    .editor-surface {
      min-height: 420px;
      border: 1px solid #d1d5db;
      border-radius: 16px;
      padding: 1.25rem 1.35rem;
      background: #fff;
      color: #111827;
      font-size: 1rem;
      line-height: 1.8;
      outline: none;
      white-space: normal;
      overflow-wrap: anywhere;
    }

    .editor-surface:focus {
      border-color: #3fb8d3;
      box-shadow: 0 0 0 4px rgba(63, 184, 211, 0.15);
    }

    .editor-surface p {
      margin: 0 0 1em 0;
    }

    .editor-surface h1,
    .editor-surface h2,
    .editor-surface h3,
    .editor-surface h4,
    .editor-surface h5,
    .editor-surface h6 {
      margin: 1.15em 0 0.6em;
      line-height: 1.3;
      font-weight: 800;
    }

    .editor-surface h2 { font-size: 1.4rem; }
    .editor-surface h3 { font-size: 1.2rem; }

    .editor-surface hr {
      margin: 1.2em 0;
      border: 0;
      border-top: 1px solid #e5e7eb;
    }

    .editor-surface ul,
    .editor-surface ol {
      margin: 0 0 1em 1.4em;
      padding: 0;
    }

    .editor-surface li {
      margin: 0.35em 0;
    }

    .editor-surface blockquote {
      margin: 1em 0;
      padding: 0.9em 1em;
      border-left: 4px solid #3fb8d3;
      background: #f8fdff;
      color: #374151;
    }

    .editor-preview {
      max-height: 240px;
      overflow: auto;
      background: #0f172a;
      color: #e2e8f0;
      border-radius: 14px;
      padding: 1rem;
      font-size: 12px;
      line-height: 1.6;
      white-space: pre-wrap;
      word-break: break-word;
    }
  </style>
</BaseLayout>
