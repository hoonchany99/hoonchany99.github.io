---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Hero } from '../components/Hero';
import { About } from '../components/About';
import { TopicHubs } from '../components/TopicHubs';
import { getCollection } from 'astro:content';
import { topicHubs, findTopicHub } from '../data/topicHubs';

const posts = (await getCollection('posts')).sort(
  (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)
);
const latestPosts = posts.slice(0, 6);

const hubCounts: Record<string, number> = {};
for (const hub of topicHubs) {
  hubCounts[hub.slug] = posts.filter((post) => {
    const matched = findTopicHub(post.data.tags ?? []);
    return matched?.slug === hub.slug;
  }).length;
}

function getExcerpt(body: string, maxLen = 100): string {
  const text = body.replace(/<[^>]+>/g, '').replace(/&[a-z]+;/gi, ' ').replace(/\s+/g, ' ').trim();
  if (text.length <= maxLen) return text;
  return text.slice(0, maxLen).replace(/\s\S*$/, '') + '…';
}

function getReadingTime(body: string): number {
  const text = body.replace(/<[^>]+>/g, '').replace(/&[a-z]+;/gi, ' ').replace(/\s+/g, ' ').trim();
  return Math.max(1, Math.round(text.length / 500));
}
---

<BaseLayout title="서울대 윤원장의 치과사전" description="충치, 신경치료, 임플란트, 사랑니 발치, 라미네이트, 크라운, 스케일링까지. 서울대 치의학대학원 출신 치과의사가 치과 치료가 막막할 때 기준이 되는 설명을 정확하고 쉽게 풀어드립니다. 100편 이상의 주제별 가이드를 확인하세요.">
  <Hero />

  <!-- 주제별 허브 -->
  <div class="anim-fade-up">
    <TopicHubs hubCounts={hubCounts} />
  </div>

  <!-- 최신 블로그 포스트 -->
  <section class="py-14 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10 md:mb-16 anim-fade-up">
        <h2 class="text-2xl md:text-4xl font-extrabold text-gray-900 mb-2 md:mb-4">최신 글</h2>
        <p class="text-sm md:text-lg text-gray-600">진료실에서 미처 다 하지 못한 이야기들을 기록합니다</p>
      </div>

      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        {latestPosts.map((post, i) => (
          <a href={`/posts/${post.slug}/`} class={`anim-fade-up anim-delay-${Math.min(i + 1, 3)} bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-0.5 cursor-pointer group border border-gray-100 flex flex-row ${i >= 4 ? 'hidden md:flex' : ''}`}>
            <div class="hidden sm:block sm:w-32 md:w-40 flex-shrink-0 overflow-hidden bg-gradient-to-br from-teal-50 to-cyan-50">
              {post.data.image?.path ? (
                <img
                  src={post.data.image.path}
                  alt={post.data.image.alt || post.data.title}
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
              ) : (
                <div class="w-full h-full min-h-[160px] flex items-center justify-center">
                  <div class="text-5xl">📝</div>
                </div>
              )}
            </div>
            <div class="p-4 sm:p-6 flex flex-col justify-center flex-1 min-w-0">
              <div class="flex items-center gap-2 md:gap-3 mb-2 md:mb-3 flex-wrap">
                {post.data.categories?.[0] && (
                  <span class="bg-brand/10 text-brand px-2.5 py-0.5 rounded-full text-[11px] md:text-xs font-semibold">{post.data.categories[0]}</span>
                )}
                {post.data.date && (
                  <span class="text-[11px] md:text-xs text-gray-400">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                )}
              </div>
              <h3 class="text-base md:text-lg font-bold text-gray-900 mb-1.5 md:mb-2 group-hover:text-brand transition-colors leading-snug">{post.data.title}</h3>
              <p class="text-gray-500 text-xs md:text-sm leading-relaxed line-clamp-2">{getExcerpt(post.body)}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-8 md:mt-12 anim-fade-up">
        <a href="/posts/" class="bg-brand text-white px-8 py-3.5 rounded-xl hover:bg-brand-dark transition-colors font-bold inline-block text-sm md:text-base min-h-[44px] flex items-center justify-center mx-auto w-fit">
          전체 글 보기
        </a>
      </div>
    </div>
  </section>

  <div class="anim-fade-up">
    <About />
  </div>

  <!-- CTA 배너 -->
  <section class="py-8 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 anim-scale-in">
      <div class="bg-gradient-to-r from-brand to-brand-dark rounded-2xl p-6 md:p-12 text-center text-white">
        <h3 class="text-lg md:text-2xl font-bold mb-2 md:mb-3">
          <span class="md:hidden">어디서부터 알아봐야 할지 막막하다면</span>
          <span class="hidden md:inline">치과 치료, 어디서부터 알아봐야 할지 막막하다면</span>
        </h3>
        <p class="text-white/80 mb-5 md:mb-6 text-sm md:text-base">주제별 가이드에서 내 상황에 맞는 글을 찾아보세요</p>
        <a href="/topics/"
          class="inline-block bg-white text-brand-dark px-6 md:px-8 py-3.5 rounded-xl font-bold hover:-translate-y-0.5 hover:shadow-lg transition-all text-sm md:text-base min-h-[44px]">
          주제별 가이드 보기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
