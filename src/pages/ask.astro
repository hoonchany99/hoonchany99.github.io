---
import BaseLayout from '../layouts/BaseLayout.astro';
import { AskSearch } from '../components/AskSearch';
---

<BaseLayout title="글 찾기 — 서울대 윤원장의 치과사전" description="궁금한 치과 질문을 입력하면 블로그 글을 바탕으로 관련 내용을 찾고 짧게 정리해드립니다. 신경치료, 임플란트, 사랑니, 크라운, 잇몸 관리 등 100편 이상의 치과 정보에서 내 질문에 맞는 글을 바로 찾아보세요.">
  <section class="py-16 min-h-[70vh]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <AskSearch client:load />
    </div>
  </section>
</BaseLayout>
