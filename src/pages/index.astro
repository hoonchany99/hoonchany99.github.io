---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Hero } from '../components/Hero';
import { About } from '../components/About';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)
);
const latestPosts = posts.slice(0, 6);

function getExcerpt(body: string, maxLen = 100): string {
  const text = body.replace(/<[^>]+>/g, '').replace(/&[a-z]+;/gi, ' ').replace(/\s+/g, ' ').trim();
  if (text.length <= maxLen) return text;
  return text.slice(0, maxLen).replace(/\s\S*$/, '') + '…';
}

function getReadingTime(body: string): number {
  const text = body.replace(/<[^>]+>/g, '').replace(/&[a-z]+;/gi, ' ').replace(/\s+/g, ' ').trim();
  return Math.max(1, Math.round(text.length / 500));
}
---

<BaseLayout title="서울대 윤원장의 치과사전" description="임플란트, 충치, 신경치료, 사랑니, 라미네이트, 스케일링까지. 서울대 치의학대학원 출신 치과의사가 진료실에서 미처 전하지 못한 치과 정보를 정확하고 쉽게 전합니다.">
  <Hero />

  <!-- 최신 블로그 포스트 -->
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 anim-fade-up">
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">최신 글</h2>
        <p class="text-lg text-gray-600">진료실에서 미처 다 하지 못한 이야기들을 기록합니다</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {latestPosts.map((post, i) => (
          <a href={`/posts/${post.slug}/`} class={`anim-fade-up anim-delay-${Math.min(i + 1, 3)} bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-0.5 cursor-pointer group border border-gray-100 flex flex-row`}>
            <div class="hidden sm:block sm:w-32 md:w-40 flex-shrink-0 overflow-hidden bg-gradient-to-br from-teal-50 to-cyan-50">
              {post.data.image?.path ? (
                <img
                  src={post.data.image.path}
                  alt={post.data.image.alt || post.data.title}
                  loading="lazy"
                  class="w-full h-full object-cover"
                />
              ) : (
                <div class="w-full h-full min-h-[160px] flex items-center justify-center">
                  <div class="text-5xl">📝</div>
                </div>
              )}
            </div>
            <div class="p-5 sm:p-6 flex flex-col justify-center flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-3 flex-wrap">
                {post.data.categories?.[0] && (
                  <span class="bg-brand/10 text-brand px-3 py-0.5 rounded-full text-xs font-semibold">{post.data.categories[0]}</span>
                )}
                {post.data.date && (
                  <span class="text-xs text-gray-400">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                )}
                <span class="text-xs text-gray-400">{getReadingTime(post.body)}분 읽기</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-brand transition-colors leading-snug">{post.data.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{getExcerpt(post.body)}</p>
              <div class="flex items-center text-brand font-semibold mt-3 text-sm group-hover:gap-2 transition-all">
                <span>더 읽기 →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      {posts.length > 6 && (
        <div class="text-center mt-12 anim-fade-up">
          <a href="/posts/" class="bg-brand text-white px-8 py-3 rounded-lg hover:bg-brand-dark transition-colors font-bold inline-block">
            더 많은 글 보기
          </a>
        </div>
      )}
    </div>
  </section>

  <div class="anim-fade-up">
    <About />
  </div>

  <!-- CTA 배너 -->
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 anim-scale-in">
      <div class="bg-gradient-to-r from-brand to-brand-dark rounded-2xl p-8 md:p-12 text-center text-white">
        <h3 class="text-2xl font-bold mb-3">진료실에서 미처 전하지 못한 이야기</h3>
        <p class="text-white/80 mb-6">정확한 정보만, 치과의사가 직접 기록합니다</p>
        <a href="/posts/"
          class="inline-block bg-white text-brand-dark px-8 py-3 rounded-lg font-bold hover:-translate-y-0.5 hover:shadow-lg transition-all">
          글 전체 보기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
